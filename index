<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ProteQt — Seguros de compras</title>
<!-- seQura Brand Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  /* ========== RESET & BASE ========== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* seQura Brand Colors */
    --primary: #00C2A3;
    --primary-dark: #00A88D;
    --primary-light: #21CCAC;
    --primary-bg: #C8FFE8;
    --primary-bg-soft: #E8FFF5;
    --success: #00C2A3;
    --success-bg: #C8FFE8;
    --warning: #F59E0B;
    --warning-bg: #FEF3C7;
    --danger: #EF4444;
    --danger-bg: #FEE2E2;
    --info: #3B82F6;
    --info-bg: #DBEAFE;
    /* seQura Grays */
    --gray-50: #F9F9F7;
    --gray-100: #F0F0E7;
    --gray-200: #E5E5DE;
    --gray-300: #D0D0D0;
    --gray-400: #8B8B8D;
    --gray-500: #6B6B6D;
    --gray-600: #4B4B4D;
    --gray-700: #333333;
    --gray-800: #1C1C1C;
    --gray-900: #1C1C1C;
    /* Radii */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 20px;
    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    --transition: 0.2s ease;
    /* Fonts */
    --font-heading: 'Bricolage Grotesque', -apple-system, sans-serif;
    --font-body: 'Open Sans', -apple-system, sans-serif;
  }

  body {
    font-family: var(--font-body);
    background: var(--gray-50);
    color: var(--gray-800);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }

  /* ========== APP SHELL ========== */
  .app-container {
    max-width: 430px;
    margin: 0 auto;
    background: #FFFFFF;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* ========== HEADER ========== */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--gray-100);
  }

  .header-close {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    font-size: 18px;
    color: var(--gray-600);
  }
  .header-close:hover { background: var(--gray-200); }

  .header-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }

  .header-title span {
    color: var(--primary);
  }

  .header-help {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--gray-200);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-500);
  }
  .header-help:hover { border-color: var(--primary); color: var(--primary); }

  /* ========== CONTENT ========== */
  .content {
    padding: 0 20px 100px;
  }

  /* ========== SECTION TITLES ========== */
  .section-title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    color: var(--gray-900);
    margin: 28px 0 14px;
    letter-spacing: -0.2px;
  }

  .section-subtitle {
    font-size: 13px;
    color: var(--gray-500);
    margin-top: -8px;
    margin-bottom: 14px;
  }

  /* ========== TABS (Mejora: filtro de tipo de seguro) ========== */
  .insurance-tabs {
    display: flex;
    gap: 8px;
    margin: 20px 0 6px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .insurance-tabs::-webkit-scrollbar { display: none; }

  .tab-pill {
    flex-shrink: 0;
    padding: 8px 16px;
    border-radius: 100px;
    border: 1.5px solid var(--gray-200);
    background: white;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-600);
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
  }
  .tab-pill:hover { border-color: var(--primary-light); color: var(--primary-dark); }
  .tab-pill.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  /* ========== CLAIMS CARDS ========== */
  .claims-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .claim-card {
    background: white;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 14px;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }
  .claim-card:hover {
    border-color: var(--primary-light);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }
  .claim-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }
  .claim-card.status-open::before { background: var(--warning); }
  .claim-card.status-rejected::before { background: var(--danger); }
  .claim-card.status-approved::before { background: var(--success); }

  .claim-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .claim-store {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-900);
  }

  .claim-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 100px;
    letter-spacing: 0.2px;
  }
  .badge-open { background: var(--warning-bg); color: #B45309; }
  .badge-rejected { background: var(--danger-bg); color: #DC2626; }
  .badge-approved { background: var(--primary-bg); color: var(--primary-dark); }

  .claim-type {
    font-size: 12px;
    color: var(--gray-500);
    margin-bottom: 6px;
  }

  .claim-detail {
    font-size: 13px;
    color: var(--gray-600);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .claim-detail svg { flex-shrink: 0; }

  /* ========== PRODUCTS CAROUSEL ========== */
  .carousel-wrapper {
    margin: 0 -20px;
    padding: 0 20px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .carousel-wrapper::-webkit-scrollbar { display: none; }

  .carousel-track {
    display: flex;
    gap: 12px;
    padding-right: 20px;
  }

  .product-card {
    flex-shrink: 0;
    width: 140px;
    cursor: pointer;
    transition: var(--transition);
  }
  .product-card:hover { transform: translateY(-2px); }

  .product-img {
    width: 140px;
    height: 160px;
    border-radius: var(--radius-md);
    object-fit: cover;
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .product-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--gray-100), var(--gray-200));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .product-brand-logo {
    width: 40px;
    height: 40px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 800;
    color: var(--gray-800);
    box-shadow: var(--shadow-sm);
    position: absolute;
    bottom: -12px;
    left: 12px;
    border: 2px solid white;
    letter-spacing: -0.5px;
  }

  .product-info {
    padding-top: 18px;
  }

  .product-store {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-900);
  }

  .product-name {
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 1px;
  }

  /* ========== RENEWAL CARDS ========== */
  .renewal-card {
    background: white;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 16px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: var(--transition);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .renewal-card:hover {
    border-color: var(--primary-light);
    box-shadow: var(--shadow-md);
  }
  .renewal-card.urgent {
    border-color: var(--warning);
    background: linear-gradient(135deg, #FFFBEB 0%, #FFFFFF 40%);
  }

  .renewal-logo {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 800;
    color: var(--gray-700);
  }

  .renewal-info {
    flex: 1;
    min-width: 0;
  }

  .renewal-type {
    font-size: 11px;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .renewal-store {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-900);
  }

  .renewal-product {
    font-size: 12px;
    color: var(--gray-500);
  }

  .renewal-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 6px;
  }

  .renewal-countdown {
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .countdown-urgent { color: var(--warning); }
  .countdown-normal { color: var(--primary); }

  .renewal-action {
    flex-shrink: 0;
  }

  .btn-renew {
    padding: 8px 18px;
    border-radius: 100px;
    border: none;
    background: var(--primary);
    color: white;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-renew:hover { background: var(--primary-dark); transform: scale(1.03); }

  /* ========== PURCHASES LIST ========== */
  .purchase-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--gray-100);
    cursor: pointer;
    transition: var(--transition);
  }
  .purchase-item:last-child { border-bottom: none; }
  .purchase-item:hover { background: var(--gray-50); margin: 0 -8px; padding: 16px 8px; border-radius: var(--radius-sm); }

  .purchase-logo {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 9px;
    font-weight: 800;
    color: var(--gray-600);
    letter-spacing: -0.3px;
  }

  .purchase-info {
    flex: 1;
    min-width: 0;
  }

  .purchase-price {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-900);
  }

  .purchase-product {
    font-size: 13px;
    color: var(--gray-700);
    font-weight: 500;
  }

  .purchase-date {
    font-size: 12px;
    color: var(--gray-400);
  }

  .btn-policy {
    padding: 8px 16px;
    border-radius: 100px;
    border: 1.5px solid var(--primary);
    background: transparent;
    color: var(--primary);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    flex-shrink: 0;
  }
  .btn-policy:hover { background: var(--primary-bg); }

  /* ========== INCIDENT CTA ========== */
  .incident-cta {
    margin: 24px 0;
    padding: 20px;
    background: var(--gray-50);
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-align: center;
    cursor: pointer;
    transition: var(--transition);
  }
  .incident-cta:hover {
    border-color: var(--primary-light);
    background: var(--primary-bg);
  }

  .incident-icon {
    font-size: 28px;
    margin-bottom: 8px;
  }

  .incident-title {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-900);
  }

